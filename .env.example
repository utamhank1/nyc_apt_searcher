# ===== Search Criteria (configure via Settings page or here) =====
BOROUGHS=["Manhattan","Brooklyn"]
NEIGHBORHOODS=["East Village","West Village","Lower East Side","Williamsburg","Greenpoint"]
MAX_PRICE=3000
MIN_PRICE=0
MIN_BEDS=1
MIN_BATHS=1
MUST_HAVE_AMENITIES=["dishwasher"]
PREFERRED_AMENITIES=["washer/dryer in unit","doorman","gym"]
WORK_ADDRESS=
LEAD_SCORE_THRESHOLD=70
SOURCES_ENABLED={"streeteasy": true, "zillow": true}

# ===== Search Partners (up to 3, CC'd on broker emails) =====
SEARCH_PARTNER_EMAILS=[]

# ===== Your Info (for broker email signature) =====
USER_NAME=
USER_EMAIL=
USER_PHONE=

# ===== API Auth =====
API_KEY=change-me-in-production

# ===== Resend (Email) — https://resend.com =====
RESEND_API_KEY=
RESEND_FROM_EMAIL=alerts@yourdomain.com
ALERT_TO_EMAIL=you@gmail.com

# ===== Telegram Bot — Talk to @BotFather to create =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== Google Maps (for commute times) — https://console.cloud.google.com =====
GOOGLE_MAPS_API_KEY=

# ===== Custom Email Template =====
USE_CUSTOM_EMAIL_TEMPLATE=false
CUSTOM_EMAIL_SUBJECT=Inquiry about {{address}} - {{source}}
CUSTOM_EMAIL_BODY=Hi {{broker_name}},\n\nI came across your listing at {{address}} ({{beds}}BR/{{baths}}BA, {{price}}/mo) and I'm very interested in scheduling a viewing.\n\nCould you share available times this week?\n\nBest regards,\n{{your_name}}\n{{your_phone}}

# ===== Scraper =====
SCRAPE_INTERVAL_HOURS=6
